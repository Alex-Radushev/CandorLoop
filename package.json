{
  "name": "candorloop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An AI reasoning companion that keeps the goal, tests the judgment, and explains the change.",
  "scripts": {
    "dev": "next dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "postbuild": "node scripts/copy-hosting-config.mjs",
    "build:next": "next build --webpack",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "start:next": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:smoke:next": "node scripts/smoke-test.mjs --next"
  },
  "dependencies": {
    "next": "16.2.10",
    "openai": "6.48.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-rsc": "^0.5.26",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "^19.2.7",
    "typescript": "^5.9.3",
    "vinext": "^0.0.50",
    "vite": "^8.1.5",
    "vitest": "^4.0.0",
    "wrangler": "^4.92.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
