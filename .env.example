# Server-side only. Never expose this value through NEXT_PUBLIC_*.
OPENAI_API_KEY=

# Use the explicit Build Week model identifier.
OPENAI_MODEL=gpt-5.6-sol

# Optional: force the deterministic local engine for screenshots or offline tests.
CANDORLOOP_DEMO_MODE=false

# Public deployment origin, used only to resolve social preview URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
